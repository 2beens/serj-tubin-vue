{
  "name": "serj-tubin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve --port 8080 --watch",
    "build-local": "vue-cli-service --mode development build",
    "build": "vue-cli-service --mode production build",
    "lint": "vue-cli-service lint",
    "serve-dev": "vue-cli-service serve --port 8080 --mode development --watch",
    "serve-prod": "vue-cli-service serve --port 8080 --mode production --watch",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js",
    "test:e2e": "cypress open",
    "test:e2e:run": "cypress run",
    "prettier:check": "prettier --check \"**/*.js\" \"**/*.vue\"",
    "prettier:write": "prettier --write \"**/*.js\" \"**/*.vue\""
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "cypress": "14.5.4",
    "roboto-fontface": "^0.10.0",
    "vue": "^2.7.16",
    "vue-chartjs": "^5.3.3",
    "vue-cookieconsent-component": "^1.2.0",
    "vue-router": "^3.6.5",
    "vuetify": "^2.7.2"
  },
  "devDependencies": {
    "@vue/cli-plugin-eslint": "^5.0.9",
    "@vue/cli-plugin-router": "^5.0.9",
    "@vue/cli-service": "^5.0.9",
    "@vue/eslint-config-standard": "^8.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-cypress": "^2.15.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-standard": "^4.1.0",
    "eslint-plugin-vue": "^9.33.0",
    "eslint-plugin-vuetify": "1.1.0",
    "prettier": "^2.8.8",
    "vue-cli-plugin-vuetify": "~2.5.8",
    "vue-template-compiler": "^2.7.16",
    "@vue/test-utils": "^1.3.6",
    "@vue/vue2-jest": "^27.0.0-alpha.3",
    "jest": "^27.5.1",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2"
  }
